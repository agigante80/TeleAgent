# Required — Telegram
TG_BOT_TOKEN=your-telegram-bot-token
TG_CHAT_ID=your-telegram-chat-id
# ALLOWED_USERS=123456789,987654321   # optional, comma-separated Telegram user IDs

# Required — GitHub
# NOTE: Copilot CLI requires a Fine-grained PAT (github_pat_...) with "Copilot Requests" permission.
#       Classic PATs (ghp_...) are NOT supported by Copilot CLI.
#       For non-Copilot backends (codex, api) a classic PAT is fine for repo access.
COPILOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxx   # used by Copilot CLI (fine-grained PAT, Copilot Requests permission)
GITHUB_REPO_TOKEN=ghp_xxxxxxxxxxxx            # used for git clone/push (any PAT with repo scope; can differ from Copilot token)
GITHUB_REPO=owner/repo
# BRANCH=main   # default: main

# Local repo path (optional)
# Set REPO_HOST_PATH to a directory on your HOST machine to bind-mount it into the container.
# The project will be cloned there on first run and reused on every restart — no re-cloning.
# Leave unset to use an internal Docker named volume (repo_data).
# REPO_HOST_PATH=/home/me/projects/VPNSentinel

# Bot behavior
# BOT_CMD_PREFIX=ta           # utility prefix → /tarun /tasync /tagit /tastatus /tahelp /tainfo
# MAX_OUTPUT_CHARS=3000       # truncate / summarize output beyond this length
# HISTORY_ENABLED=true        # set to false to disable conversation history storage
# STREAM_RESPONSES=true       # set to false to wait for full response before sending

# ── AI Backend ──────────────────────────────────────────────────────────────

# Option 1: GitHub Copilot CLI (default)
AI_CLI=copilot
# COPILOT_MODEL=gpt-4o        # optional model override
# COPILOT_SKILLS_DIRS=/skills # mount a volume with custom skills

# Option 2: OpenAI Codex CLI
# AI_CLI=codex
# AI_API_KEY=sk-xxxxxxxxxxxx
# CODEX_MODEL=o3              # default: o3

# Option 3: Direct API (openai | anthropic | ollama | openai-compat)
# AI_CLI=api
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxxxxxxxxxx
# AI_MODEL=gpt-4o

# AI_CLI=api
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-xxxxxxxxxxxx
# AI_MODEL=claude-3-5-sonnet-20241022

# AI_CLI=api
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2
# AI_BASE_URL=http://host.docker.internal:11434
