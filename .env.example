# AgentGate — environment variables
# This file lists the most common variables to get started.
# Full reference with all options and defaults: README.md → Environment Variables

# ── Platform ──────────────────────────────────────────────────────────────────
PLATFORM=telegram   # telegram | slack

# ── Telegram (required when PLATFORM=telegram) ────────────────────────────────
TG_BOT_TOKEN=your-telegram-bot-token
TG_CHAT_ID=your-telegram-chat-id
# ALLOWED_USERS=123456789,987654321   # optional extra allowlist

# ── Slack (required when PLATFORM=slack) ──────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...            # Socket Mode app-level token
# SLACK_CHANNEL_ID=C0123456789        # required for the 🟢 Ready message

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO_TOKEN=ghp_xxxxxxxxxxxx   # PAT with repo scope (clone/push)
GITHUB_REPO=owner/repo
# BRANCH=main

# ── AI Backend (choose one) ───────────────────────────────────────────────────

# Option 1: GitHub Copilot CLI (default)
AI_CLI=copilot
COPILOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxx   # fine-grained PAT, Copilot Requests permission

# Option 2: OpenAI Codex CLI
# AI_CLI=codex
# AI_API_KEY=sk-xxxxxxxxxxxx
# AI_MODEL=o3

# Option 3: Direct API (openai | anthropic | ollama | openai-compat)
# AI_CLI=api
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxxxxxxxxxx
# AI_MODEL=gpt-4o
